# Copy to .env.local for the Taskfile. Do not commit .env.local.

# PCT 102 (or any test box) reachable over SSH as root for `task deploy`/`task seed`.
HIVEDOCK_DEPLOY_HOST=192.168.1.102

# Override where dev/compose looks for stacks (defaults to ./dev-stacks locally).
# STACKS_DIR=/opt/stacks-test

# Disable auth for local/LAN testing.
AUTH_DISABLED=true
